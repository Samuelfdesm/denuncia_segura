<%- include('partials/header.ejs'); %>
<%- include('partials/navbar.ejs'); %>

<a href="https://www.google.com" class="btn btn-dark quick-exit">Sair rápido</a>

<header>
    <h1 class="h4">Denúncia Anônima</h1>
    <p class="mb-0">Seu relato é seguro e pode salvar vidas</p>
</header>

<div class="container my-4">

<form action="/form-denuncia" method="POST">

<!-- 1. Sobre a ocorrência -->
<div class="card mb-3 shadow-sm">
<div class="card-body">
<h5 class="card-title mb-3">1. Sobre a ocorrência</h5>

<div class="mb-3">
    <label class="form-label">Tipo de violência</label>
    <div class="row mt-2">
        <% tipo_violencia.forEach(tipo => { %>
            <div class="col-6 col-md-4">
                <div class="form-check ms-2">
                    <input class="form-check-input"
                           type="checkbox"
                           name="tipos_violencia"
                           value="<%= tipo.id_valor %>">
                    <label class="form-check-label">
                        <%= tipo.valor %>
                    </label>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<div class="mb-3">
    <label class="form-label">Descreva o ocorrido</label>
    <textarea class="form-control" name="descricao" rows="4" required></textarea>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label class="form-label">Data</label>
        <input type="date" name="data_ocorrencia" class="form-control" required>
    </div>

    <div class="col-md-6 mb-3">
        <label class="form-label">Frequência</label>
        <select class="form-select" name="frequencia" required>
            <% frequencia.forEach(f => { %>
                <option value="<%= f.id_valor %>"><%= f.valor %></option>
            <% }) %>
        </select>
    </div>
</div>

</div>
</div>

<!-- 2. Localização -->
<div class="card mb-3 shadow-sm">
<div class="card-body">
<h5 class="card-title mb-3">2. Localização</h5>

<div class="row">
    <div class="col-md-6 mb-3">
        <label class="form-label">Cidade</label>
        <input type="text" name="cidade" class="form-control">
    </div>

    <div class="col-md-6 mb-3">
        <label class="form-label">Bairro</label>
        <input type="text" name="bairro" class="form-control">
    </div>
</div>

<div class="mb-3">
    <label class="form-label">Endereço (opcional)</label>
    <input type="text" name="endereco" class="form-control">
</div>

</div>
</div>

<!-- 3. Agressor -->
<div class="card mb-3 shadow-sm">
<div class="card-body">
<h5 class="card-title mb-3">3. Sobre o agressor</h5>

<div class="mb-3">
    <label class="form-label">Relação com a vítima</label>
    <select class="form-select" name="relacao_vitima" required>
        <% relacao_vitima.forEach(r => { %>
            <option value="<%= r.id_valor %>"><%= r.valor %></option>
        <% }) %>
    </select>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label class="form-label">Está presente?</label>
        <select name="agressor_presente" class="form-select">
            <option value="1">Sim</option>
            <option value="0">Não</option>
        </select>
    </div>

    <div class="col-md-6 mb-3">
        <label class="form-label">Álcool/Drogas</label>
        <select name="usa_alcool_drogas" class="form-select">
            <% usa_alcool_drogas.forEach(u => { %>
                <option value="<%= u.id_valor %>"><%= u.valor %></option>
            <% }) %>
        </select>
    </div>
</div>

</div>
</div>

<!-- 4. Risco -->
<div class="card mb-3 shadow-sm">
<div class="card-body">
<h5 class="card-title mb-3">4. Nível de risco</h5>

<div class="row">
    <div class="col-md-4 mb-3">
        <label class="form-label">Risco imediato</label>
        <select name="risco_imediato" class="form-select">
            <option value="1">Sim</option>
            <option value="0">Não</option>
        </select>
    </div>

    <div class="col-md-4 mb-3">
        <label class="form-label">Criança/Idoso</label>
        <select name="crianca_idoso" class="form-select">
            <option value="1">Sim</option>
            <option value="0">Não</option>
        </select>
    </div>

    <div class="col-md-4 mb-3">
        <label class="form-label">Acesso a armas</label>
        <select name="existe_acesso_armas" class="form-select">
            <% existe_acesso_armas.forEach(a => { %>
                <option value="<%= a.id_valor %>"><%= a.valor %></option>
            <% }) %>
        </select>
    </div>
</div>

</div>
</div>

<!-- 5. Contato -->
<div class="card mb-3 shadow-sm">
<div class="card-body">
<h5 class="card-title mb-3">5. Contato (opcional)</h5>

<div class="mb-3">
    <label class="form-label">Deseja contato?</label>
    <select name="deseja_contato" class="form-select">
        <option value="0">Não</option>
        <option value="1">Sim</option>
    </select>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label class="form-label">Telefone</label>
        <input type="text" name="telefone" class="form-control">
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control">
    </div>
</div>

</div>
</div>

<!-- 6. Confirmação -->
<div class="card mb-3 shadow-sm">
<div class="card-body">
<h5 class="card-title mb-3">6. Confirmação</h5>

<div class="form-check">
    <input class="form-check-input" type="checkbox" name="confirmacao" value="1" required>
    <label class="form-check-label">
        Confirmo que as informações são verdadeiras
    </label>
</div>

</div>
</div>

<button class="btn btn-danger w-100 py-3">Enviar denúncia</button>

</form>
</div>

<%- include('partials/footer.ejs'); %>