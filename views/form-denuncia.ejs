<form action="/form-denuncia" method="POST" novalidate>

<!-- 1. Sobre a ocorrência -->
<div class="card mb-3 shadow-sm">
<div class="card-body">
<h5 class="card-title mb-3">1. Sobre a ocorrência</h5>

<div class="mb-3">
<label class="form-label">Tipo de violência</label>
<div class="row mt-2">
<% tipo_violencia.forEach(tipo => { %>
<div class="col-6 col-md-4">
<div class="form-check ms-2">
<input class="form-check-input"
type="checkbox"
name="tipos_violencia"
value="<%= tipo.id_valor %>"
<%= Array.isArray(dadosForm?.tipos_violencia)
    ? dadosForm.tipos_violencia.includes(String(tipo.id_valor)) ? "checked" : ""
    : dadosForm?.tipos_violencia == tipo.id_valor ? "checked" : ""
%>>

<label class="form-check-label">
<%= tipo.valor %>
</label>
</div>
</div>
<% }) %>
</div>
</div>

<div class="mb-3">
<label class="form-label">Descreva o ocorrido</label>
<textarea class="form-control" name="descricao" rows="4"><%= dadosForm?.descricao || "" %></textarea>
</div>

<div class="row">
<div class="col-md-6 mb-3">
<label class="form-label">Data</label>
<input type="date" name="data_ocorrencia" class="form-control"
value="<%= dadosForm?.data_ocorrencia || "" %>">
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Frequência</label>
<select class="form-select" name="frequencia">
<% frequencia.forEach(f => { %>
<option value="<%= f.id_valor %>"
<%= dadosForm?.frequencia == f.id_valor ? "selected" : "" %>>
<%= f.valor %>
</option>
<% }) %>
</select>
</div>
</div>

</div>
</div>

<!-- 2. Localização -->
<div class="card mb-3 shadow-sm">
<div class="card-body">
<h5 class="card-title mb-3">2. Localização</h5>

<div class="row">
<div class="col-md-6 mb-3">
<label class="form-label">Cidade</label>
<input type="text" name="cidade" class="form-control"
value="<%= dadosForm?.cidade || "" %>">
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Bairro</label>
<input type="text" name="bairro" class="form-control"
value="<%= dadosForm?.bairro || "" %>">
</div>
</div>

<div class="mb-3">
<label class="form-label">Endereço (opcional)</label>
<input type="text" name="endereco" class="form-control"
value="<%= dadosForm?.endereco || "" %>">
</div>

</div>
</div>

<!-- 3. Agressor -->
<div class="card mb-3 shadow-sm">
<div class="card-body">
<h5 class="card-title mb-3">3. Sobre o agressor</h5>

<div class="mb-3">
<label class="form-label">Relação com a vítima</label>
<select class="form-select" name="relacao_vitima">
<% relacao_vitima.forEach(r => { %>
<option value="<%= r.id_valor %>"
<%= dadosForm?.relacao_vitima == r.id_valor ? "selected" : "" %>>
<%= r.valor %>
</option>
<% }) %>
</select>
</div>

<div class="row">
<div class="col-md-6 mb-3">
<label class="form-label">Está presente?</label>
<select name="agressor_presente" class="form-select">
<option value="1" <%= dadosForm?.agressor_presente == "1" ? "selected" : "" %>>Sim</option>
<option value="0" <%= dadosForm?.agressor_presente == "0" ? "selected" : "" %>>Não</option>
</select>
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Álcool/Drogas</label>
<select name="usa_alcool_drogas" class="form-select">
