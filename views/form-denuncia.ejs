<option value="1" <%= dadosForm?.risco_imediato == "1" ? "selected" : "" %>>Sim</option>
<option value="0" <%= dadosForm?.risco_imediato == "0" ? "selected" : "" %>>Não</option>
</select>
</div>

<div class="col-md-4 mb-3">
<label class="form-label">Criança/Idoso</label>
