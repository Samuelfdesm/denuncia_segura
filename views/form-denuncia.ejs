<%= dadosForm?.usa_alcool_drogas == u.id_valor ? "selected" : "" %>>
<%= u.valor %>
</option>
<% }) %>
</select>
</div>
</div>

</div>
</div>

<!-- 4. Risco -->
<div class="card mb-3 shadow-sm">
<div class="card-body">
<h5 class="card-title mb-3">4. Nível de risco</h5>

