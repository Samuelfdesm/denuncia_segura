</select>
</div>

<div class="col-md-4 mb-3">
<label class="form-label">Acesso a armas</label>
<select name="existe_acesso_armas" class="form-select">
<% existe_acesso_armas.forEach(a => { %>
<option value="<%= a.id_valor %>"
<%= dadosForm?.existe_acesso_armas == a.id_valor ? "selected" : "" %>>
<%= a.valor %>
</option>
<% }) %>
</select>
</div>
</div>

</div>
</div>

<!-- 5. Contato -->
<div class="card mb-3 shadow-sm">
<div class="card-body">
<h5 class="card-title mb-3">5. Contato (opcional)</h5>

<div class="mb-3">
<label class="form-label">Deseja contato?</label>
<select name="deseja_contato" class="form-select">
<option value="0" <%= dadosForm?.deseja_contato == "0" ? "selected" : "" %>>Não</option>
<option value="1" <%= dadosForm?.deseja_contato == "1" ? "selected" : "" %>>Sim</option>
</select>
</div>

<div class="row">
<div class="col-md-6 mb-3">
<label class="form-label">Telefone</label>
<input type="text" name="telefone" class="form-control"
value="<%= dadosForm?.telefone || "" %>">
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Email</label>
<input type="email" name="email" class="form-control"
value="<%= dadosForm?.email || "" %>">
</div>
</div>

</div>
</div>

<!-- 6. Confirmação -->
<div class="card mb-3 shadow-sm">
<div class="card-body">
<h5 class="card-title mb-3">6. Confirmação</h5>

<div class="form-check">
<input class="form-check-input"
type="checkbox"
name="confirmacao"
value="1"
<%= dadosForm?.confirmacao ? "checked" : "" %>>

<label class="form-check-label">
Confirmo que as informações são verdadeiras
</label>
</div>

</div>
</div>

<button class="btn btn-danger w-100 py-3">Enviar denúncia</button>

</form>
</div>

<script>
function sairRapido() {
    // 🔥 limpa dados locais
    localStorage.clear();
    sessionStorage.clear();

    // (opcional) limpar cookies básicos
    document.cookie.split(";").forEach(function(c) {
        document.cookie = c.replace(/^ +/, "")
            .replace(/=.*/, "=;expires=" + new Date().toUTCString() + ";path=/");
    });

    // 🚀 redireciona sem deixar histórico
    window.location.replace("https://www.google.com");
}
</script>

